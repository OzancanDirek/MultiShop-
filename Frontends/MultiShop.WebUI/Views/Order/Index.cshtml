@model CreateOrderAdressDto
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/UILayout/_UILayout.cshtml";
}

<div class="container-fluid">
    <form method="post">
        <div class="row px-xl-5">

            <!-- SOL TARAF -->
            <div class="col-lg-8">
                <h5 class="section-title position-relative text-uppercase mb-3">
                    <span class="bg-secondary pr-3">
                        Sipariş Teslimat ve Fatura Adresi
                    </span>
                </h5>

                <div class="bg-light p-30 mb-5">
                    <div class="row">

                        <div class="col-md-6 form-group">
                            <label>Adınız</label>
                            <input class="form-control" type="text" asp-for="Name" placeholder="Adınız">
                        </div>

                        <div class="col-md-6 form-group">
                            <label>Soyadınız</label>
                            <input class="form-control" type="text" asp-for="Surname" placeholder="Soyadınız">
                        </div>

                        <div class="col-md-6 form-group">
                            <label>E-mail</label>
                            <input class="form-control" type="text" asp-for="Email" placeholder="ornek@email.com">
                        </div>

                        <div class="col-md-6 form-group">
                            <label>Telefon Numaranız</label>
                            <input class="form-control" type="text" asp-for="Phone" placeholder="+90 123 456 7892">
                        </div>

                        <div class="col-md-6 form-group">
                            <label>Adres Satır 1</label>
                            <input class="form-control" type="text" asp-for="Detail1" placeholder="123 mahallesi">
                        </div>

                        <div class="col-md-6 form-group">
                            <label>Adres Satır 2</label>
                            <input class="form-control" type="text" asp-for="Detail2" placeholder="345 sokak">
                        </div>

                        <div class="col-md-6 form-group">
                            <label>Ülke</label>
                            <input class="form-control" type="text" asp-for="Country" placeholder="Türkiye">
                        </div>

                        <div class="col-md-6 form-group">
                            <label>Şehir</label>
                            <input class="form-control" type="text" asp-for="City" placeholder="Şehriniz">
                        </div>

                        <div class="col-md-6 form-group">
                            <label>İlçe</label>
                            <input class="form-control" type="text" asp-for="District" placeholder="İlçe">
                        </div>

                        <div class="col-md-6 form-group">
                            <label>Posta Kodu</label>
                            <input class="form-control" type="text" asp-for="ZipCode" placeholder="34000">
                        </div>

                    </div>

                    <!-- SUBMIT BUTON -->
                    <div class="text-right mt-3">
                        <button type="submit" class="btn btn-primary px-4">
                            Siparişi Tamamla
                        </button>
                    </div>

                </div>
            </div>

            <!-- SAĞ TARAF -->
            <div class="col-lg-4">
                <h5 class="section-title position-relative text-uppercase mb-3">
                    <span class="bg-secondary pr-3">
                        Sipariş Özeti
                    </span>
                </h5>

                @await Component.InvokeAsync("_OrderSummaryComponentPartial")
                @await Component.InvokeAsync("_PaymentMethodComponentPartial")
            </div>

        </div>
    </form>
</div>
