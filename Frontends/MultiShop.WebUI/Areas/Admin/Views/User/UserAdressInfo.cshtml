@model GetCargoCustomerByIdDto
@{
    ViewData["Title"] = "UserAdressInfo";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content container-fluid">
    <div class="row">

        <div class="col-md-12">
            <div class="chart-box">
                <h4>Kullanıcı Adress ve İletişim Bilgisi</h4>
                <p>Kullanıcıyla alakalı bilgilere aşağıdan erişebilirsiniz.</p>
                <div class="bs-example" data-example-id="bordered-table">
                    <h3>Kullanıcı Profil Bilgisi</h3>
                    <div class="alert alert-info">Kullanıcı Id: @Model.cargoCustomerId</div>
                    <div class="alert alert-warning">Kullanıcı Adı Soyadı: @Model.name @Model.surname</div>
                    <div class="alert alert-info">Email Adresi: @Model.email</div>
                    <div class="alert alert-warning">Telefon Numarası: @Model.phone</div>
                    <div class="alert alert-info">İlçe-Şehir: @Model.district @Model.city</div>
                    <div class="alert alert-warning">Adress: @Model.adress</div>
                </div>
            </div>
        </div>

    </div>
</section>

