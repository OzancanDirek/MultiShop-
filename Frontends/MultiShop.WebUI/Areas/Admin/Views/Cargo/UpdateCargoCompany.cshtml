@model UpdateCargoCompanyDto

@{
    ViewData["Title"] = "UpdateCargoCompany";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

@{
    ViewData["Title"] = "CreateCargoCompany";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content container-fluid">
    <div class="row">

        <div class="col-md-12">
            <div class="chart-box">
                <div class="bs-example" data-example-id="bordered-table">

                    <form method="post" asp-controller="Cargo" asp-action="UpdateCargoCompany" asp-area="Admin">
                        <input type="hidden" asp-for="cargoCompanyId">
                        <div class="form-group">
                            <label>Kargo Şirketi Adı</label>
                            <input type="text" class="form-control" asp-for="cargoCompanyName" />
                        </div>
                        <button type="submit" class="btn btn-success">Kargo Şirketini Güncelle</button>
                    </form>
                </div>
            </div>
        </div>

    </div>
</section>

