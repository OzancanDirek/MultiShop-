@model List<ResultOrderingByUserIdDto>
@{
    ViewData["Title"] = "Sipariş Geçmişim";
    Layout = "~/Areas/User/Views/UserLayout/Index.cshtml";
    int count = 0;
}

<div class="main-panel">
    <div class="content-wrapper">

        <div class="row mb-4">
            <div class="col-12">
                <h3 class="fw-bold">📦 Sipariş Geçmişim</h3>
                <p class="text-muted">Tüm siparişlerinizi buradan görüntüleyebilirsiniz.</p>
            </div>
        </div>

        <div class="row g-4">
            @foreach (var item in Model)
            {
                count++;
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card border-0 shadow-lg h-100 rounded-4">
                        <div class="card-body d-flex flex-column">

                            <!-- Üst Alan -->
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-info rounded-pill px-3 py-2">
                                    Sipariş #@count
                                </span>
                                <small class="text-muted">
                                    @item.OrderDate.ToString("dd MMM yyyy")
                                </small>
                            </div>

                            <!-- Fiyat -->
                            <div class="mb-4">
                                <h4 class="fw-bold text-success">
                                    @item.TotalPrice ₺
                                </h4>
                                <span class="text-muted small">Toplam Ödeme</span>
                            </div>

                            <!-- Spacer -->
                            <div class="mt-auto text-end">
                                <a href="#"
                                   class="btn btn-outline-primary rounded-pill px-4">
                                    Sipariş Detayları →
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>

    </div>
</div>
