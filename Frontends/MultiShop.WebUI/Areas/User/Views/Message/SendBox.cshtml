@model List<ResultSendBoxMessageDto>
@{
    ViewData["Title"] = "Gelen Mesajlar";
    Layout = "~/Areas/User/Views/UserLayout/Index.cshtml";
}

<div class="main-panel">
    <div class="content-wrapper">

        <!-- Başlık -->
        <div class="row mb-4">
            <div class="col-12">
                <h3 class="fw-bold">📥 Giden Mesajlar</h3>
                <p class="text-muted">Tarafınızdan Gönderilen tüm mesajları buradan görüntüleyebilirsiniz</p>
            </div>
        </div>

        <!-- Mesaj Listesi -->
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-0">

                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Alıcı</th>
                            <th>Konu</th>
                            <th>Tarih</th>
                            <th>Durum</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@(item.IsRead ? "" : "table-warning")">

                                <!-- Gönderen -->
                                <td>
                                    <div class="fw-semibold">
                                        @item.SenderId
                                    </div>
                                </td>

                                <!-- Konu -->
                                <td>
                                    <div class="fw-bold text-dark">
                                        @item.Subject
                                    </div>
                                </td>

                                <!-- Tarih -->
                                <td>
                                    <small class="text-muted">
                                        @item.MessageDate.ToString("dd MMM yyyy HH:mm")
                                    </small>
                                </td>

                                <!-- Okundu Durumu -->
                                <td>
                                    @if (item.IsRead)
                                    {
                                        <span class="badge bg-success rounded-pill px-3">
                                            Okundu
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger rounded-pill px-3">
                                            Okunmadı
                                        </span>
                                    }
                                </td>

                                <!-- Butonlar -->
                                <td class="text-end">
                                    <a href="#"
                                       class="btn btn-sm btn-outline-info rounded-pill px-3 me-2">
                                        Mesajı Aç
                                    </a>

                                    <a href="#"
                                       class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                        Sil
                                    </a>
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>

    </div>
</div>